# OrionHealth Environment Variables
# Copy to .env and fill in your values
# WARNING: .env is gitignored. NEVER commit real keys.

# ---------------------------------------------------------------------------
# Google Gemini API (cloud fallback for AI assistant when local model unavailable)
# Get key: https://aistudio.google.com/apikey
# ---------------------------------------------------------------------------
GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# HuggingFace Token (for downloading local models via flutter_gemma)
# Get token: https://huggingface.co/settings/tokens (read-only is sufficient)
# ---------------------------------------------------------------------------
HUGGINGFACE_TOKEN=

# ---------------------------------------------------------------------------
# OpenAI API (optional cloud provider)
# Get key: https://platform.openai.com/api-keys
# ---------------------------------------------------------------------------
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Custom Provider (OpenAI-compatible API, e.g. local llama.cpp, vLLM, Ollama)
# ---------------------------------------------------------------------------
CUSTOM_API_BASE_URL=
CUSTOM_API_KEY=
