# IHCE Gateway Configuration
PORT=3000
NODE_ENV=development

# IHCE OAuth2 Configuration
IHCE_AUTH_URL=https://vulcano.ihcecol.gov.co/auth/realms/ihce/protocol/openid-connect/auth
IHCE_TOKEN_URL=https://vulcano.ihcecol.gov.co/auth/realms/ihce/protocol/openid-connect/token
IHCE_CLIENT_ID=your_client_id
IHCE_CLIENT_SECRET=your_client_secret
IHCE_REDIRECT_URI=http://localhost:3000/api/auth/ihce/callback

# FHIR Base URL
IHCE_FHIR_BASE_URL=https://vulcano.ihcecol.gov.co/fhir

# Security
ENCRYPTION_KEY=your_32_char_encryption_key_here
SESSION_SECRET=your_session_secret_here

# Optional: Redis configuration for session storage
# REDIS_URL=redis://localhost:6379
