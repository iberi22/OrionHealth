---
const base = import.meta.env.BASE_URL || '/OrionHealth';
const screenshots = [
  { src: `${base}/screenshots/01_main_navigation.png`, title: 'Secure Login', description: 'PIN & biometric authentication with AES-256 encryption' },
  { src: `${base}/screenshots/02_profile_page.png`, title: 'Health Profile', description: 'Personal health profile with medical history management' },
  { src: `${base}/screenshots/03_records_page.png`, title: 'Medications & Records', description: 'Track medications, dosages, and health records (FHIR-compatible)' },
  { src: `${base}/screenshots/08_chat_interface.png`, title: 'Voice AI Assistant', description: 'On-device AI voice chat — all processing stays local' },
  { src: `${base}/screenshots/09_reports_list.png`, title: 'Health Reports', description: 'AI-generated reports analyzing your health trends' },
  { src: `${base}/screenshots/05_reports_page.png`, title: 'Medical Research', description: 'Search ICD-10, LOINC, SNOMED & clinical guidelines' },
  { src: `${base}/screenshots/07_profile_form.png`, title: 'PIN Security', description: '6-digit PIN setup for secure local access' },
];
---

<section id="screenshots" class="relative py-16 md:py-24 px-4 bg-gradient-to-b from-transparent to-charcoal/30">
  <div class="container-custom">
    <div class="max-w-4xl mx-auto mb-12 text-center">
      <h2 class="section-title font-bold tracking-tighter uppercase mb-4 md:mb-6" data-animate>
        APP <span class="text-accent">PREVIEW</span>
      </h2>
      <p class="text-sm md:text-base text-bone-dark max-w-2xl mx-auto leading-relaxed opacity-80">
        Take a look at OrionHealth's clean, privacy-focused interface designed for your health journey.
      </p>
    </div>

    <!-- Screenshots Carousel - Horizontal scroll on mobile, grid on desktop -->
    <div class="relative max-w-6xl mx-auto">
      <!-- Mobile: Horizontal scroll carousel -->
      <div class="flex md:hidden overflow-x-auto snap-x snap-mandatory scrollbar-hide gap-4 pb-4 -mx-4 px-4">
        {screenshots.map((screenshot, index) => (
          <div class="flex-shrink-0 w-48 snap-center">
            <div class="flashlight-card glass rounded-xl overflow-hidden group">
              <div class="aspect-[9/16] bg-charcoal overflow-hidden">
                <img
                  src={screenshot.src}
                  alt={screenshot.title}
                  class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <div class="p-3">
                <h3 class="font-bold text-sm text-bone-dark">{screenshot.title}</h3>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Desktop: 2-column grid -->
      <div class="hidden md:grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
        {screenshots.map((screenshot, index) => (
          <div
            class="flashlight-card glass rounded-xl overflow-hidden group cursor-pointer"
            data-animate
            style={`animation-delay: ${index * 100}ms`}
          >
            <div class="aspect-[9/16] bg-charcoal overflow-hidden">
              <img
                src={screenshot.src}
                alt={screenshot.title}
                class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-charcoal via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
                <div class="text-white">
                  <h3 class="font-bold text-sm md:text-base">{screenshot.title}</h3>
                  <p class="text-xs text-bone-dark opacity-80">{screenshot.description}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Feature badges under gallery -->
    <div class="flex flex-wrap justify-center gap-3 mt-8" data-animate>
      <span class="text-xs px-3 py-1.5 rounded-full border border-accent/30 text-accent bg-accent/10">
        🔒 100% Private
      </span>
      <span class="text-xs px-3 py-1.5 rounded-full border border-secondary/30 text-secondary bg-secondary/10">
        🤖 Local AI
      </span>
      <span class="text-xs px-3 py-1.5 rounded-full border border-bone/20 text-bone-dark bg-bone/5">
        📊 Health Insights
      </span>
      <span class="text-xs px-3 py-1.5 rounded-full border border-accent/30 text-accent bg-accent/10">
        ✨ Material 3 Design
      </span>
    </div>
  </div>
</section>

<style>
  .flashlight-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .flashlight-card:hover {
    border-color: rgba(16, 185, 129, 0.3);
    box-shadow: 0 0 30px rgba(16, 185, 129, 0.1);
  }

  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
