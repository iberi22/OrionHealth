---
// GitHubLiveStatus.astro - GitHub stats dashboard.
// Renders instantly from bundled fallback data, then hydrates live counts
// from the GitHub REST API (client-side, with graceful fallback).
import projectStats from "../data/project-stats.json";
import githubStats from "../data/github-stats.json";

const { github, ci } = projectStats;
const repo = githubStats.repo;
const owner = githubStats.owner;
const apiUrl = githubStats.apiUrl;
const repoUrl = githubStats.url;

interface Stat {
  key: string;
  label: string;
  value: number;
  suffix?: string;
  color: string;
  icon: string;
}

const stats: Stat[] = [
  { key: "stars", label: "Stars", value: github.stars, color: "#FBBF24",
    icon: '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>' },
  { key: "forks", label: "Forks", value: github.forks, color: "#8B5CF6",
    icon: '<line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/>' },
  { key: "openIssues", label: "Open Issues", value: github.openIssues, color: "#F59E0B",
    icon: '<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>' },
  { key: "contributors", label: "Contributors", value: github.contributors, color: "#3B82F6",
    icon: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>' },
];
---

<div class="ghs-section" data-ghs data-api={apiUrl}>
  <div class="ghs-header">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
    </svg>
    <h3>GitHub</h3>
    <span class="ghs-live"><span class="ghs-live-dot"></span><span class="ghs-live-text">live</span></span>
    <a href={repoUrl} class="ghs-link" target="_blank" rel="noopener noreferrer">{owner}/{repo} ↗</a>
  </div>

  <div class="ghs-grid">
    {
      stats.map((s) => (
        <div class="ghs-stat" style={`--accent:${s.color}`}>
          <div class="ghs-stat-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill={s.color} fillOpacity="0.18" stroke={s.color} stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon} />
          </div>
          <div class="ghs-stat-num" data-stat={s.key}>{s.value}{s.suffix}</div>
          <div class="ghs-stat-label">{s.label}</div>
        </div>
      ))
    }
    <div class="ghs-stat ghs-stat--ci" style={`--accent:${ci.status === "passing" ? "#10B981" : "#EF4444"}`}>
      <div class="ghs-stat-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
      </div>
      <div class="ghs-stat-num">{ci.passRate}%</div>
      <div class="ghs-stat-label">CI Pass Rate</div>
    </div>
  </div>

  <div class="ghs-ci-row">
    <span class={`ghs-ci-badge ${ci.status}`}>
      <span class="ghs-ci-dot"></span>
      CI: {ci.status}
    </span>
    <span class="ghs-ci-text">
      Last build: <strong>{ci.lastBuild}</strong> · {ci.totalRuns} runs
    </span>
    <span class="ghs-meta">{githubStats.license} · {githubStats.language}</span>
  </div>

  <p class="ghs-desc">{githubStats.description}</p>
</div>

<style is:global>
  .ghs-section { margin: 2.5rem 0; }
  .ghs-header { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.25rem; }
  .ghs-header h3 { margin: 0; font-size: 1.25rem; font-weight: 600; color: #E5E7EB; }
  .ghs-live { display: inline-flex; align-items: center; gap: 0.35rem; padding: 0.15rem 0.5rem; border-radius: 999px; font-size: 0.65rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: #10B981; background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.25); }
  .ghs-live-dot { width: 6px; height: 6px; border-radius: 50%; background: #10B981; box-shadow: 0 0 6px rgba(16,185,129,0.7); animation: ghsPulse 2s infinite; }
  .ghs-section:not([data-live]) .ghs-live-dot { animation: none; opacity: 0.5; }
  @keyframes ghsPulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }
  .ghs-link { margin-left: auto; font-size: 0.8rem; color: #10B981; text-decoration: none; font-family: 'Fira Code', 'Cascadia Code', monospace; }
  .ghs-link:hover { text-decoration: underline; }

  .ghs-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 0.75rem; margin-bottom: 1rem; }
  .ghs-stat {
    padding: 1rem; border-radius: 12px; text-align: center;
    border: 1px solid rgba(255,255,255,0.06);
    background: rgba(255,255,255,0.02);
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    position: relative; overflow: hidden;
  }
  .ghs-stat:hover { background: rgba(255,255,255,0.05); transform: translateY(-3px); border-color: color-mix(in srgb, var(--accent) 45%, transparent); box-shadow: 0 12px 28px -16px color-mix(in srgb, var(--accent) 70%, transparent); }
  .ghs-stat-icon { margin-bottom: 0.4rem; display: flex; justify-content: center; }
  .ghs-stat-num { font-size: 1.55rem; font-weight: 700; color: #E5E7EB; font-family: 'Fira Code', 'Cascadia Code', monospace; line-height: 1.1; }
  .ghs-stat-label { font-size: 0.72rem; color: #6B7280; text-transform: uppercase; letter-spacing: 0.04em; margin-top: 0.15rem; }
  .ghs-stat--ci { color: var(--accent); }

  .ghs-ci-row { display: flex; flex-wrap: wrap; align-items: center; gap: 0.75rem 1rem; padding: 0.75rem 1rem; border-radius: 10px; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04); }
  .ghs-ci-badge { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.25rem 0.75rem; border-radius: 999px; font-size: 0.78rem; font-weight: 600; font-family: 'Fira Code', 'Cascadia Code', monospace; }
  .ghs-ci-badge.passing { background: rgba(16,185,129,0.15); color: #10B981; border: 1px solid rgba(16,185,129,0.3); }
  .ghs-ci-badge.failing { background: rgba(239,68,68,0.15); color: #EF4444; border: 1px solid rgba(239,68,68,0.3); }
  .ghs-ci-dot { width: 8px; height: 8px; border-radius: 50%; background: currentColor; box-shadow: 0 0 6px currentColor; }
  .ghs-ci-text { font-size: 0.8rem; color: #6B7280; }
  .ghs-ci-text strong { color: #9CA3AF; }
  .ghs-meta { margin-left: auto; font-size: 0.72rem; color: #4B5563; font-family: 'Fira Code', 'Cascadia Code', monospace; }
  .ghs-desc { margin: 0.85rem 0 0; font-size: 0.78rem; color: #6B7280; line-height: 1.5; }

  @media (max-width: 520px) {
    .ghs-meta { margin-left: 0; }
  }
</style>

<script>
  // Hydrate live counts from the GitHub REST API. Falls back silently to the
  // bundled values on rate-limit / offline / error, so the card never breaks.
  (function () {
    const root = document.currentScript?.closest('[data-ghs]') as HTMLElement | null;
    const section = root || document.querySelector<HTMLElement>('[data-ghs]');
    if (!section) return;
    const api = section.getAttribute('data-api');
    if (!api) return;

    const setStat = (key: string, value: number) => {
      const el = section.querySelector<HTMLElement>(`[data-stat="${key}"]`);
      if (el && Number.isFinite(value)) el.textContent = String(value);
    };

    fetch(api, { headers: { Accept: 'application/vnd.github+json' } })
      .then((res) => (res.ok ? res.json() : Promise.reject(new Error(String(res.status)))))
      .then((data) => {
        if (!data || data.message) return; // rate-limited / error envelope
        section.setAttribute('data-live', 'true');
        setStat('stars', data.stargazers_count);
        setStat('forks', data.forks_count);
        setStat('openIssues', data.open_issues_count);
        setStat('contributors', data.subscribers_count ?? undefined);
      })
      .catch(() => {
        /* keep bundled fallback values */
      });
  })();
</script>
