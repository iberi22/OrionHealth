---
import { ui } from "../i18n/ui";
import DonationSection from "./DonationSection.astro";
import FeatureCard from "./FeatureCard.astro";
import Footer from "./Footer.astro";
import Header from "./Header.astro";
import ScreenshotsGallery from "./ScreenshotsGallery.astro";

interface Props {
	lang?: string;
}

const { lang = "en" } = Astro.props;
const t = ui[lang as keyof typeof ui] || ui.en;
---

<Header lang={lang} />

<main class="pt-16 md:pt-20 safe-area-top">
  <!-- Hero Section -->
  <section class="relative min-h-[90vh] md:min-h-screen flex items-center justify-center overflow-hidden py-12 md:py-20 px-4">
    <div class="relative z-10 container-custom">
      <div class="max-w-5xl mx-auto text-center">
        <!-- Trust Badge -->
        <div class="mb-6 md:mb-8 animate-fade-in-up" style="opacity: 0;">
          <span class="trust-badge inline-flex items-center gap-2">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            Privacy-First • Open Source • AGPL-3.0
          </span>
        </div>

        <!-- Main Heading -->
        <h1 class="hero-title font-bold tracking-tighter uppercase mb-6 md:mb-8 animate-fade-in-up stagger-1" style="opacity: 0;">
          {t.heroTitle}
          <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent via-secondary to-accent-light">
            {t.heroSubtitle}
          </span>
        </h1>

        <!-- Subheading -->
        <p class="text-base sm:text-lg md:text-xl lg:text-2xl text-bone-dark max-w-2xl mx-auto leading-relaxed mb-8 md:mb-12 animate-fade-in-up stagger-2 px-4" style="opacity: 0;">
          {t.heroDescription}
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4 animate-fade-in-up stagger-3 px-4" style="opacity: 0;">
          <a
            href="#download"
            class="btn-primary w-full sm:w-auto px-6 sm:px-8 py-3 sm:py-4 text-xs sm:text-sm text-center"
          >
            {t.heroCtaPrimary}
          </a>
          <a
            href="https://github.com/iberi22/OrionHealth"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-secondary w-full sm:w-auto px-6 sm:px-8 py-3 sm:py-4 text-xs sm:text-sm text-center flex items-center justify-center gap-2"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            {t.heroCtaSecondary}
          </a>
          <a
            href="/OrionHealth/medical-standards"
            class="btn-secondary w-full sm:w-auto px-6 sm:px-8 py-3 sm:py-4 text-xs sm:text-sm text-center flex items-center justify-center gap-2"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            Explore Medical Knowledge Base
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section id="features" class="relative py-16 md:py-32 px-4">
    <div class="container-custom">
      <div class="text-center mb-10 md:mb-16" data-animate>
        <span class="text-[10px] sm:text-xs font-bold uppercase tracking-[0.2em] sm:tracking-[0.3em] text-bone-dark opacity-40 mb-3 sm:mb-4 block">
          Core Features
        </span>
        <h2 class="section-title font-bold tracking-tighter uppercase">
          {t.featureTitle}
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
        <FeatureCard
          icon="🔒"
          title={t.feature1Title}
          description={t.feature1Desc}
          delay={0}
        />
        <FeatureCard
          icon="🧠"
          title={t.feature2Title}
          description={t.feature2Desc}
          delay={0.1}
        />
        <FeatureCard
          icon="🌍"
          title={t.feature3Title}
          description={t.feature3Desc}
          delay={0.2}
        />
        <FeatureCard
          icon="🔍"
          title={t.feature4Title}
          description={t.feature4Desc}
          delay={0.3}
        />
        <FeatureCard
          icon="🔐"
          title={t.feature5Title}
          description={t.feature5Desc}
          delay={0.4}
        />
        <FeatureCard
          icon="🔓"
          title="Open Source"
          description="AGPL-3.0 licensed. Full transparency. Audit the code yourself. Community-driven development."
          delay={0.5}
        />
      </div>
    </div>
  </section>

  <!-- Mission Statement Section -->
  <section id="mission" class="relative py-16 md:py-32 px-4 bg-gradient-to-b from-transparent to-charcoal/30">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-10 md:mb-16" data-animate>
          <span class="text-[10px] sm:text-xs font-bold uppercase tracking-[0.2em] sm:tracking-[0.3em] text-bone-dark opacity-40 mb-3 sm:mb-4 block">
            {t.missionTitle}
          </span>
          <h2 class="section-title font-bold tracking-tighter uppercase mb-4 md:mb-8">
            {t.missionStatement}
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
          <div class="flashlight-card glass rounded-xl md:rounded-2xl p-6 md:p-8" data-animate>
            <h3 class="text-lg sm:text-xl font-bold mb-2 flex items-center gap-2">
              <span class="text-accent">✓</span> {t.mission1}
            </h3>
          </div>
          <div class="flashlight-card glass rounded-xl md:rounded-2xl p-6 md:p-8" data-animate>
            <h3 class="text-lg sm:text-xl font-bold mb-2 flex items-center gap-2">
              <span class="text-accent">✓</span> {t.mission2}
            </h3>
          </div>
          <div class="flashlight-card glass rounded-xl md:rounded-2xl p-6 md:p-8" data-animate>
            <h3 class="text-lg sm:text-xl font-bold mb-2 flex items-center gap-2">
              <span class="text-accent">✓</span> {t.mission3}
            </h3>
          </div>
          <div class="flashlight-card glass rounded-xl md:rounded-2xl p-6 md:p-8" data-animate>
            <h3 class="text-lg sm:text-xl font-bold mb-2 flex items-center gap-2">
              <span class="text-accent">✓</span> {t.mission4}
            </h3>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Screenshots Gallery -->
  <ScreenshotsGallery />

  <!-- Medical Standards Section -->
  <section id="standards" class="relative py-16 md:py-32 px-4">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-10 md:mb-16" data-animate>
          <span class="text-[10px] sm:text-xs font-bold uppercase tracking-[0.2em] sm:tracking-[0.3em] text-bone-dark opacity-40 mb-3 sm:mb-4 block">
            Medical Knowledge Base
          </span>
          <h2 class="section-title font-bold tracking-tighter uppercase mb-4 md:mb-8">
            EXPLORE <span class="text-accent">628</span> MEDICAL CODES
          </h2>
          <p class="text-sm md:text-base text-bone-dark leading-relaxed opacity-80 max-w-2xl mx-auto mb-6">
            OrionHealth ships with a complete offline medical standards database:
            ICD-10, LOINC, RxNorm, and SNOMED CT for accurate medical reference.
          </p>
          <a
            href="/OrionHealth/medical-standards"
            class="btn-primary inline-flex items-center gap-2 px-8 py-4 text-sm"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            Browse Medical Standards
          </a>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto">
          <div class="glass rounded-xl p-6 text-center hover:scale-105 transition-transform" data-animate>
            <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center mx-auto mb-3">
              <span class="text-white font-bold text-xs">ICD</span>
            </div>
            <div class="text-2xl font-bold">278</div>
            <div class="text-xs text-bone-dark opacity-60">ICD-10 Codes</div>
          </div>
          <div class="glass rounded-xl p-6 text-center hover:scale-105 transition-transform" data-animate>
            <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-emerald-500 to-emerald-700 flex items-center justify-center mx-auto mb-3">
              <span class="text-white font-bold text-xs">LOINC</span>
            </div>
            <div class="text-2xl font-bold">145</div>
            <div class="text-xs text-bone-dark opacity-60">Lab Tests</div>
          </div>
          <div class="glass rounded-xl p-6 text-center hover:scale-105 transition-transform" data-animate>
            <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-purple-500 to-purple-700 flex items-center justify-center mx-auto mb-3">
              <span class="text-white font-bold text-xs">RxN</span>
            </div>
            <div class="text-2xl font-bold">118</div>
            <div class="text-xs text-bone-dark opacity-60">Medications</div>
          </div>
          <div class="glass rounded-xl p-6 text-center hover:scale-105 transition-transform" data-animate>
            <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-amber-500 to-amber-700 flex items-center justify-center mx-auto mb-3">
              <span class="text-white font-bold text-xs">SNM</span>
            </div>
            <div class="text-2xl font-bold">87</div>
            <div class="text-xs text-bone-dark opacity-60">Concepts</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Privacy Section -->
  <section id="privacy" class="relative py-16 md:py-32 px-4">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-10 md:mb-16" data-animate>
          <span class="text-[10px] sm:text-xs font-bold uppercase tracking-[0.2em] sm:tracking-[0.3em] text-bone-dark opacity-40 mb-3 sm:mb-4 block">
            Privacy Commitment
          </span>
          <h2 class="section-title font-bold tracking-tighter uppercase mb-4 md:mb-8">
            YOUR DATA IS <span class="text-accent">SACRED</span>
          </h2>
        </div>

        <div class="space-y-4 md:space-y-6">
          <div class="flashlight-card glass rounded-xl md:rounded-2xl p-6 md:p-8" data-animate>
            <h3 class="text-lg sm:text-xl md:text-2xl font-bold mb-2 md:mb-4 flex items-center gap-2 md:gap-3">
              <span class="text-accent text-base sm:text-lg">✓</span> No Cloud Storage
            </h3>
            <p class="text-sm md:text-base text-bone-dark leading-relaxed opacity-80">
              All your health data is stored locally on your device using Isar database.
              We don't have servers to hack because we don't have servers.
            </p>
          </div>

          <div class="flashlight-card glass rounded-xl md:rounded-2xl p-6 md:p-8" data-animate>
            <h3 class="text-lg sm:text-xl md:text-2xl font-bold mb-2 md:mb-4 flex items-center gap-2 md:gap-3">
              <span class="text-accent text-base sm:text-lg">✓</span> Local AI Processing
            </h3>
            <p class="text-sm md:text-base text-bone-dark leading-relaxed opacity-80">
              All AI features run on-device. Your conversations with your health data
              stay private. No API calls, no data transmission.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Blog Section -->
  <section id="blog" class="relative py-16 md:py-32 px-4 bg-gradient-to-b from-transparent to-charcoal/30">
    <div class="container-custom">
      <div class="text-center mb-10 md:mb-16" data-animate>
        <span class="text-[10px] sm:text-xs font-bold uppercase tracking-[0.2em] sm:tracking-[0.3em] text-bone-dark opacity-40 mb-3 sm:mb-4 block">
          {t.blogTitle}
        </span>
        <h2 class="section-title font-bold tracking-tighter uppercase mb-4 md:mb-8">
          {t.blogSubtitle}
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-6xl mx-auto">
        <!-- Real Blog Posts -->
        <a href="/OrionHealth/blog/privacy-in-the-age-of-ai" class="flashlight-card glass rounded-xl overflow-hidden group" data-animate>
          <div class="p-6">
            <span class="text-[10px] text-accent uppercase tracking-widest mb-2 block">Technology</span>
            <h3 class="text-xl font-bold mb-3 group-hover:text-accent transition-colors">Privacy in the Age of AI</h3>
            <p class="text-sm text-bone-dark opacity-70 mb-4">How on-device processing is changing the landscape of medical data security.</p>
            <span class="text-xs font-bold">Read More →</span>
          </div>
        </a>
        <a href="/OrionHealth/blog/understanding-your-vitals" class="flashlight-card glass rounded-xl overflow-hidden group" data-animate>
          <div class="p-6">
            <span class="text-[10px] text-secondary uppercase tracking-widest mb-2 block">Health</span>
            <h3 class="text-xl font-bold mb-3 group-hover:text-secondary transition-colors">Understanding Your Vitals</h3>
            <p class="text-sm text-bone-dark opacity-70 mb-4">Why tracking daily metrics can lead to better long-term health outcomes.</p>
            <span class="text-xs font-bold">Read More →</span>
          </div>
        </a>
        <a href="/OrionHealth/blog" class="flashlight-card glass rounded-xl overflow-hidden group" data-animate>
          <div class="p-6">
            <span class="text-[10px] text-accent uppercase tracking-widest mb-2 block">Explore More</span>
            <h3 class="text-xl font-bold mb-3 group-hover:text-accent transition-colors">More from our blog</h3>
            <p class="text-sm text-bone-dark opacity-70 mb-4">Discover more articles about privacy, healthcare, and our mission.</p>
            <span class="text-xs font-bold">View All Posts →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Support Section -->
  <section id="support" class="relative py-16 md:py-32 px-4">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-10 md:mb-16" data-animate>
          <span class="text-[10px] sm:text-xs font-bold uppercase tracking-[0.2em] sm:tracking-[0.3em] text-bone-dark opacity-40 mb-3 sm:mb-4 block">
            Community Support
          </span>
          <h2 class="section-title font-bold tracking-tighter uppercase mb-4 md:mb-8">
            GET <span class="text-accent">HELP</span>
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-1 gap-4 md:gap-6">
          <!-- GitHub Issues Card -->
          <div class="flashlight-card glass rounded-xl md:rounded-2xl p-6 md:p-8" data-animate>
            <div class="flex items-center gap-4 mb-4">
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-[#333] to-[#1a1a1a] flex items-center justify-center border border-white/10">
                <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
              </div>
              <div>
                <h3 class="text-lg md:text-xl font-bold">GitHub Issues</h3>
                <p class="text-xs text-bone-dark opacity-60">Direct issue creation</p>
              </div>
            </div>
            <a href="https://github.com/iberi22/OrionHealth/issues" target="_blank" rel="noopener noreferrer" class="btn-secondary w-full py-3 text-xs text-center block">View GitHub Issues</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Donation Section -->
  <DonationSection lang={lang} />

  <!-- Download Section -->
  <section id="download" class="relative py-16 md:py-32 px-4">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="section-title font-bold tracking-tighter uppercase mb-4 md:mb-8" data-animate>
          GET <span class="text-accent">STARTED</span>
        </h2>
        <p class="text-sm md:text-xl text-bone-dark mb-8 md:mb-12 px-4" data-animate>
          OrionHealth is currently in active development. Star us on GitHub to get notified of releases.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4 px-4" data-animate>
          <a
            href="https://github.com/iberi22/OrionHealth/releases"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary w-full sm:w-auto px-6 sm:px-8 py-3 sm:py-4 text-xs sm:text-sm text-center"
          >
            Download APK
          </a>
          <a
            href="https://github.com/iberi22/OrionHealth"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-secondary w-full sm:w-auto px-6 sm:px-8 py-3 sm:py-4 text-xs sm:text-sm text-center flex items-center justify-center gap-2"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            Star on GitHub
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Medical Disclaimer -->
  <section class="relative py-12 px-4 border-t border-accent/10">
    <div class="container-custom max-w-4xl mx-auto">
      <div class="glass p-6 rounded-xl border-l-4 border-accent" data-animate>
        <h4 class="text-accent font-bold mb-2">{t.disclaimerTitle}</h4>
        <p class="text-xs md:text-sm text-bone-dark opacity-80 leading-relaxed">
          {t.disclaimerText}
        </p>
      </div>
    </div>
  </section>
</main>

<Footer lang={lang} />
