---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, author, heroImage, tags } = post.data;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout title={title} description={description}>
  <Header />

  <main class="pt-24 md:pt-32 pb-16 px-4 safe-area-top">
    <article class="container-custom max-w-4xl mx-auto">
      <!-- Post Header -->
      <header class="mb-12 text-center">
        <div class="mb-6 flex items-center justify-center gap-3 text-xs uppercase tracking-widest text-accent font-bold">
          <time datetime={pubDate.toISOString()}>
            {pubDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
          <span class="w-1 h-1 rounded-full bg-bone-dark/40"></span>
          <span>{author}</span>
        </div>

        <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold tracking-tighter uppercase mb-6 leading-tight">
          {title}
        </h1>

        <p class="text-lg md:text-xl text-bone-dark opacity-80 leading-relaxed max-w-2xl mx-auto">
          {description}
        </p>

        {tags && (
          <div class="flex flex-wrap justify-center gap-2 mt-8">
            {tags.map((tag) => (
              <span class="text-[10px] px-3 py-1 rounded-full border border-accent/20 bg-accent/5 text-accent uppercase tracking-widest">
                {tag}
              </span>
            ))}
          </div>
        )}
      </header>

      <!-- Hero Image -->
      {heroImage && (
        <div class="mb-12 rounded-2xl overflow-hidden glass p-1">
          <img src={heroImage} alt="" class="w-full h-auto rounded-xl" />
        </div>
      )}

      <!-- Content -->
      <div class="glass p-6 md:p-12 rounded-2xl">
        <div class="prose prose-invert prose-emerald max-w-none
          prose-headings:uppercase prose-headings:tracking-tighter prose-headings:font-bold
          prose-p:text-bone-dark prose-p:leading-relaxed
          prose-li:text-bone-dark
          prose-strong:text-accent prose-strong:font-bold
          prose-a:text-accent hover:prose-a:text-secondary transition-colors">
          <slot />
        </div>
      </div>

      <!-- Post Footer -->
      <footer class="mt-12 pt-8 border-t border-white/5 flex flex-col md:flex-row items-center justify-between gap-6">
        <a href={`${base}/blog`} class="btn-secondary px-6 py-3 text-xs flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to Blog
        </a>

        <div class="flex items-center gap-4">
          <span class="text-xs text-bone-dark opacity-60">Share this post:</span>
          <!-- Basic social shares could go here -->
          <div class="flex gap-2">
            <button class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center hover:bg-accent/10 hover:border-accent/50 transition-all">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.84 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
            </button>
          </div>
        </div>
      </footer>
    </article>
  </main>

  <Footer />
</BaseLayout>

<style is:global>
  /* Extra styling for Markdown content since we don't have Tailwind Typography plugin installed (or I should check) */
  .prose h1, .prose h2, .prose h3, .prose h4 {
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: #F5F5DC; /* bone */
  }
  .prose h1 { font-size: 2.25rem; }
  .prose h2 { font-size: 1.875rem; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.5rem; }
  .prose h3 { font-size: 1.5rem; }
  .prose p { margin-bottom: 1.25rem; }
  .prose ul { list-style-type: disc; padding-left: 1.5rem; margin-bottom: 1.25rem; }
  .prose li { margin-bottom: 0.5rem; }
</style>
