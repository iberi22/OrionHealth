---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="Security - OrionHealth"
  description="OrionHealth security policy — supported versions, vulnerability reporting, and responsible disclosure"
  lang="en"
>
  <Header lang="en" />

  <main class="pt-16 md:pt-20 safe-area-top">
    <!-- Hero -->
    <section class="relative py-16 md:py-24 px-4 text-center">
      <div class="container-custom">
        <p class="text-[10px] uppercase tracking-[0.3em] text-accent mb-4" data-animate>
          PRIVACY-FIRST COMMITMENT
        </p>
        <h1 class="section-title font-bold tracking-tighter uppercase mb-6" data-animate>
          SECUR<span class="text-accent">ITY</span>
        </h1>
        <p class="text-sm md:text-base text-bone-dark max-w-3xl mx-auto opacity-80" data-animate>
          OrionHealth is a <span class="text-accent">local-first, offline-first</span> health data application.
          Your health data never leaves your device unencrypted. We do not operate cloud servers,
          track users, or collect telemetry.
        </p>
      </div>
    </section>

    <!-- Supported Versions -->
    <section class="relative py-12 px-4" data-animate>
      <div class="container-custom max-w-5xl">
        <div class="glass p-6 md:p-10 rounded-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-secondary mb-3">Section 1</p>
          <h2 class="text-xl md:text-3xl font-bold tracking-tight mb-6">SUPPORTED VERSIONS</h2>
          <p class="text-xs md:text-sm text-bone-dark leading-relaxed opacity-80 mb-4">
            Users are strongly encouraged to always use the latest beta release. Critical security fixes will be backported to the most recent minor version only.
          </p>

          <div class="overflow-x-auto">
            <table class="w-full text-xs">
              <thead>
                <tr class="glass-dark">
                  <th class="text-left p-3 font-bold text-accent uppercase tracking-wider">Version</th>
                  <th class="text-left p-3 font-bold text-accent uppercase tracking-wider">Supported</th>
                </tr>
              </thead>
              <tbody>
                <tr class="border-b border-white/5">
                  <td class="p-3 text-bone-dark opacity-80">0.7.x</td>
                  <td class="p-3"><span class="text-accent">:white_check_mark: ✔ Supported</span></td>
                </tr>
                <tr class="border-b border-white/5">
                  <td class="p-3 text-bone-dark opacity-80">0.6.x</td>
                  <td class="p-3"><span class="text-accent">:white_check_mark: ✔ Supported</span></td>
                </tr>
                <tr class="border-b border-white/5">
                  <td class="p-3 text-bone-dark opacity-80">0.5.x</td>
                  <td class="p-3"><span class="text-error">:x: ✖ Not supported</span></td>
                </tr>
                <tr>
                  <td class="p-3 text-bone-dark opacity-80">&lt; 0.5</td>
                  <td class="p-3"><span class="text-error">:x: ✖ Not supported</span></td>
                </tr>
              </tbody>
            </table>
          </div>
          <p class="text-xs text-bone-dark opacity-60 mt-4">
            <span class="text-accent">Current version:</span> 0.7.0 (beta)
          </p>
        </div>
      </div>
    </section>

    <!-- Reporting a Vulnerability -->
    <section class="relative py-12 px-4" data-animate>
      <div class="container-custom max-w-5xl">
        <div class="glass p-6 md:p-10 rounded-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-secondary mb-3">Section 2</p>
          <h2 class="text-xl md:text-3xl font-bold tracking-tight mb-6">REPORTING A VULNERABILITY</h2>
          <p class="text-xs md:text-sm text-bone-dark leading-relaxed opacity-80 mb-6">
            We take the security of OrionHealth seriously. If you believe you have found a security vulnerability, please report it privately.
          </p>

          <div class="space-y-4 mb-6">
            <div class="glass-dark p-4 md:p-6 rounded-xl">
              <h3 class="text-sm font-bold text-accent mb-2">Where to Report</h3>
              <div class="space-y-3">
                <div class="flex items-start gap-3">
                  <span class="text-accent shrink-0">1.</span>
                  <div>
                    <p class="text-xs font-bold text-bone">GitHub Private Vulnerability Report (preferred)</p>
                    <a href="https://github.com/iberi22/OrionHealth/security/advisories" target="_blank" class="text-[11px] text-accent hover:underline">
                      Navigate to Security Advisories →
                    </a>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <span class="text-accent shrink-0">2.</span>
                  <div>
                    <p class="text-xs font-bold text-bone">Email</p>
                    <a href="mailto:security@southwest-ai-labs.com" class="text-[11px] text-accent hover:underline">
                      security@southwest-ai-labs.com
                    </a>
                  </div>
                </div>
              </div>
            </div>

            <div class="glass-dark p-4 md:p-6 rounded-xl">
              <h3 class="text-sm font-bold text-accent mb-2">What to Include</h3>
              <ul class="space-y-1">
                <li class="text-[11px] text-bone-dark opacity-70">Type of issue (buffer overflow, SQL injection, XSS, etc.)</li>
                <li class="text-[11px] text-bone-dark opacity-70">Full paths of source file(s) related to the issue</li>
                <li class="text-[11px] text-bone-dark opacity-70">Location of affected source code (tag/branch/commit or URL)</li>
                <li class="text-[11px] text-bone-dark opacity-70">Any special configuration required to reproduce</li>
                <li class="text-[11px] text-bone-dark opacity-70">Step-by-step instructions to reproduce</li>
                <li class="text-[11px] text-bone-dark opacity-70">Proof-of-concept or exploit code (if possible)</li>
                <li class="text-[11px] text-bone-dark opacity-70">Impact of the issue and how an attacker might exploit it</li>
              </ul>
            </div>

            <div class="glass-dark p-4 md:p-6 rounded-xl border border-error/20">
              <h3 class="text-sm font-bold text-error mb-2">What NOT to Include</h3>
              <ul class="space-y-1">
                <li class="text-[11px] text-bone-dark opacity-70">❌ Do not post security vulnerabilities publicly on GitHub Issues</li>
                <li class="text-[11px] text-bone-dark opacity-70">❌ Do not include real health data in your report</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Disclosure Policy -->
    <section class="relative py-12 px-4" data-animate>
      <div class="container-custom max-w-5xl">
        <div class="glass p-6 md:p-10 rounded-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-secondary mb-3">Section 3</p>
          <h2 class="text-xl md:text-3xl font-bold tracking-tight mb-6">DISCLOSURE POLICY</h2>
          <p class="text-xs md:text-sm text-bone-dark leading-relaxed opacity-80 mb-4">
            We follow a <span class="text-accent">coordinated disclosure</span> process:
          </p>

          <div class="space-y-4">
            <div class="glass-dark p-4 rounded-xl">
              <div class="flex items-center gap-3">
                <span class="text-[10px] px-2 py-0.5 rounded bg-accent/20 text-accent font-bold">0–48h</span>
                <span class="text-xs text-bone-dark opacity-70">Acknowledgment of receipt</span>
              </div>
            </div>
            <div class="glass-dark p-4 rounded-xl">
              <div class="flex items-center gap-3">
                <span class="text-[10px] px-2 py-0.5 rounded bg-accent/20 text-accent font-bold">7 days</span>
                <span class="text-xs text-bone-dark opacity-70">Initial triage and validation</span>
              </div>
            </div>
            <div class="glass-dark p-4 rounded-xl">
              <div class="flex items-center gap-3">
                <span class="text-[10px] px-2 py-0.5 rounded bg-accent/20 text-accent font-bold">90 days</span>
                <span class="text-xs text-bone-dark opacity-70">Standard disclosure deadline after fix release</span>
              </div>
            </div>
          </div>

          <div class="mt-6 glass-dark p-4 rounded-xl">
            <h3 class="text-xs font-bold text-bone mb-2">Disclosure Timeline</h3>
            <ol class="space-y-1 list-decimal list-inside">
              <li class="text-[11px] text-bone-dark opacity-70"><span class="text-accent">Report received</span> — We acknowledge receipt within <span class="text-accent">48 hours</span></li>
              <li class="text-[11px] text-bone-dark opacity-70"><span class="text-accent">Investigation</span> — We validate the report within <span class="text-accent">7 days</span></li>
              <li class="text-[11px] text-bone-dark opacity-70"><span class="text-accent">Fix development</span> — We develop and test a fix</li>
              <li class="text-[11px] text-bone-dark opacity-70"><span class="text-accent">Release</span> — We publish a patched version</li>
              <li class="text-[11px] text-bone-dark opacity-70"><span class="text-accent">Public disclosure</span> — Advisory published <span class="text-accent">90 days</span> after fix</li>
            </ol>
          </div>
        </div>
      </div>
    </section>

    <!-- Scope -->
    <section class="relative py-12 px-4" data-animate>
      <div class="container-custom max-w-5xl">
        <div class="glass p-6 md:p-10 rounded-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-secondary mb-3">Section 4</p>
          <h2 class="text-xl md:text-3xl font-bold tracking-tight mb-6">SCOPE</h2>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <h3 class="text-xs font-bold text-accent mb-3 uppercase tracking-wider">In Scope</h3>
              <ul class="space-y-2">
                <li class="text-[11px] text-bone-dark opacity-70 flex items-start gap-2">
                  <span class="text-accent shrink-0">✔</span>
                  OrionHealth Flutter application (core app + all features)
                </li>
                <li class="text-[11px] text-bone-dark opacity-70 flex items-start gap-2">
                  <span class="text-accent shrink-0">✔</span>
                  Isar database encryption and data-at-rest protection
                </li>
                <li class="text-[11px] text-bone-dark opacity-70 flex items-start gap-2">
                  <span class="text-accent shrink-0">✔</span>
                  Authentication and identity management
                </li>
                <li class="text-[11px] text-bone-dark opacity-70 flex items-start gap-2">
                  <span class="text-accent shrink-0">✔</span>
                  BLE/NFC/WiFi Direct health data sharing
                </li>
                <li class="text-[11px] text-bone-dark opacity-70 flex items-start gap-2">
                  <span class="text-accent shrink-0">✔</span>
                  On-device AI (LLM inference, RAG pipeline)
                </li>
                <li class="text-[11px] text-bone-dark opacity-70 flex items-start gap-2">
                  <span class="text-accent shrink-0">✔</span>
                  Health wallet and offline storage
                </li>
              </ul>
            </div>
            <div>
              <h3 class="text-xs font-bold text-error mb-3 uppercase tracking-wider">Not In Scope</h3>
              <ul class="space-y-2">
                <li class="text-[11px] text-bone-dark opacity-70 flex items-start gap-2">
                  <span class="text-error shrink-0">✖</span>
                  Third-party dependencies
                </li>
                <li class="text-[11px] text-bone-dark opacity-70 flex items-start gap-2">
                  <span class="text-error shrink-0">✖</span>
                  Cloud services operated by third parties
                </li>
                <li class="text-[11px] text-bone-dark opacity-70 flex items-start gap-2">
                  <span class="text-error shrink-0">✖</span>
                  Physical device security (lost/stolen)
                </li>
                <li class="text-[11px] text-bone-dark opacity-70 flex items-start gap-2">
                  <span class="text-error shrink-0">✖</span>
                  Social engineering attacks
                </li>
                <li class="text-[11px] text-bone-dark opacity-70 flex items-start gap-2">
                  <span class="text-error shrink-0">✖</span>
                  OS-level vulnerabilities
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Security Features -->
    <section class="relative py-12 px-4" data-animate>
      <div class="container-custom max-w-5xl">
        <div class="glass p-6 md:p-10 rounded-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-secondary mb-3">Section 5</p>
          <h2 class="text-xl md:text-3xl font-bold tracking-tight mb-6">SECURITY FEATURES</h2>
          <p class="text-xs md:text-sm text-bone-dark leading-relaxed opacity-80 mb-4">
            OrionHealth includes these security features <span class="text-accent">by design</span>:
          </p>

          <div class="space-y-3">
            <div class="glass-dark p-4 rounded-xl flex items-start gap-3">
              <svg class="w-4 h-4 text-accent shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              <div>
                <h3 class="text-xs font-bold text-bone">Local-first storage</h3>
                <p class="text-[11px] text-bone-dark opacity-60">All data stored on-device using Isar database — no cloud uploads</p>
              </div>
            </div>
            <div class="glass-dark p-4 rounded-xl flex items-start gap-3">
              <svg class="w-4 h-4 text-accent shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
              <div>
                <h3 class="text-xs font-bold text-bone">Encrypted at rest</h3>
                <p class="text-[11px] text-bone-dark opacity-60">Sensitive health data encrypted using AES-256-GCM with PBKDF2 key derivation</p>
              </div>
            </div>
            <div class="glass-dark p-4 rounded-xl flex items-start gap-3">
              <svg class="w-4 h-4 text-accent shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
              </svg>
              <div>
                <h3 class="text-xs font-bold text-bone">Zero telemetry</h3>
                <p class="text-[11px] text-bone-dark opacity-60">No analytics, no tracking, no data collection of any kind</p>
              </div>
            </div>
            <div class="glass-dark p-4 rounded-xl flex items-start gap-3">
              <svg class="w-4 h-4 text-accent shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.858 15.355-5.858 21.213 0" />
              </svg>
              <div>
                <h3 class="text-xs font-bold text-bone">No external network calls</h3>
                <p class="text-[11px] text-bone-dark opacity-60">App functions fully offline without internet access</p>
              </div>
            </div>
            <div class="glass-dark p-4 rounded-xl flex items-start gap-3">
              <svg class="w-4 h-4 text-accent shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
              </svg>
              <div>
                <h3 class="text-xs font-bold text-bone">Prompt anonymizer</h3>
                <p class="text-[11px] text-bone-dark opacity-60">PII removal before any cloud API calls (when cloud mode is enabled)</p>
              </div>
            </div>
            <div class="glass-dark p-4 rounded-xl flex items-start gap-3">
              <svg class="w-4 h-4 text-accent shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <div>
                <h3 class="text-xs font-bold text-bone">On-device AI</h3>
                <p class="text-[11px] text-bone-dark opacity-60">Local LLM inference via Gemma 4 — health data never leaves your device</p>
              </div>
            </div>
            <div class="glass-dark p-4 rounded-xl flex items-start gap-3">
              <svg class="w-4 h-4 text-accent shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z" />
              </svg>
              <div>
                <h3 class="text-xs font-bold text-bone">BLE/NFC encryption</h3>
                <p class="text-[11px] text-bone-dark opacity-60">Health data sharing uses encrypted peer-to-peer connections</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Responsible Disclosure -->
    <section class="relative py-12 px-4" data-animate>
      <div class="container-custom max-w-5xl">
        <div class="glass p-6 md:p-10 rounded-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-secondary mb-3">Section 6</p>
          <h2 class="text-xl md:text-3xl font-bold tracking-tight mb-6">RESPONSIBLE DISCLOSURE</h2>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <h3 class="text-xs font-bold text-accent mb-3 uppercase tracking-wider">We Ask You</h3>
              <ul class="space-y-2">
                <li class="text-[11px] text-bone-dark opacity-70 flex items-start gap-2">
                  <span class="text-accent shrink-0">→</span>
                  Give us reasonable time (up to 90 days) to fix the issue
                </li>
                <li class="text-[11px] text-bone-dark opacity-70 flex items-start gap-2">
                  <span class="text-accent shrink-0">→</span>
                  Do not exploit the vulnerability or cause harm
                </li>
                <li class="text-[11px] text-bone-dark opacity-70 flex items-start gap-2">
                  <span class="text-accent shrink-0">→</span>
                  Act in good faith to help us improve security
                </li>
              </ul>
            </div>
            <div>
              <h3 class="text-xs font-bold text-accent mb-3 uppercase tracking-wider">We Commit To</h3>
              <ul class="space-y-2">
                <li class="text-[11px] text-bone-dark opacity-70 flex items-start gap-2">
                  <span class="text-accent shrink-0">→</span>
                  Responding promptly and professionally to reports
                </li>
                <li class="text-[11px] text-bone-dark opacity-70 flex items-start gap-2">
                  <span class="text-accent shrink-0">→</span>
                  Keeping you informed of progress toward a fix
                </li>
                <li class="text-[11px] text-bone-dark opacity-70 flex items-start gap-2">
                  <span class="text-accent shrink-0">→</span>
                  Giving you credit for the discovery (unless anonymous)
                </li>
                <li class="text-[11px] text-bone-dark opacity-70 flex items-start gap-2">
                  <span class="text-accent shrink-0">→</span>
                  Releasing fixes as quickly as possible
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section class="relative py-12 px-4" data-animate>
      <div class="container-custom max-w-5xl">
        <div class="glass p-6 md:p-10 rounded-2xl text-center">
          <p class="text-[10px] uppercase tracking-[0.3em] text-secondary mb-3">Section 7</p>
          <h2 class="text-xl md:text-3xl font-bold tracking-tight mb-6">CONTACT & PGP</h2>
          <p class="text-xs md:text-sm text-bone-dark leading-relaxed opacity-80 mb-6">
            We accept encrypted vulnerability reports via PGP. Request the current key fingerprint by email.
          </p>
          <div class="flex flex-wrap justify-center gap-3">
            <a href="mailto:security@southwest-ai-labs.com" class="btn-primary px-5 py-2 text-xs">
              EMAIL SECURITY TEAM
            </a>
            <a href="https://github.com/iberi22/OrionHealth/security/advisories" target="_blank" class="btn-secondary px-5 py-2 text-xs">
              GITHUB ADVISORIES
            </a>
          </div>
          <p class="text-xs text-bone-dark opacity-40 mt-6">
            Last updated: 2026-05-03
          </p>
        </div>
      </div>
    </section>

    <!-- Back link -->
    <section class="relative py-12 px-4 text-center">
      <div class="container-custom">
        <a href={`${base}/docs`} class="btn-secondary px-6 py-3 text-xs inline-block">
          ← BACK TO DOCUMENTATION
        </a>
      </div>
    </section>
  </main>

  <Footer lang="en" />
</BaseLayout>
