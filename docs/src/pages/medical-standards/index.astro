---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import fs from 'node:fs';

// Load all standards
function loadJson(file) {
  try {
    const content = fs.readFileSync(`public/${file}`, 'utf-8');
    return JSON.parse(content);
  } catch {
    return null;
  }
}

const icd10 = loadJson('icd10.json');
const loinc = loadJson('loinc.json');
const rxnorm = loadJson('rxnorm.json');
const snomed = loadJson('snomed.json');

const standards = [
  { 
    id: 'icd-10', 
    name: 'ICD-10', 
    fullName: 'International Classification of Diseases',
    count: icd10?.data?.length || 0,
    description: 'Códigos de enfermedades de la OMS',
    color: 'from-blue-500 to-blue-700',
    categories: [...new Set(icd10?.data?.map(d => d.category) || [])]
  },
  { 
    id: 'loinc', 
    name: 'LOINC', 
    fullName: 'Logical Observation Identifiers Names and Codes',
    count: loinc?.data?.length || 0,
    description: 'Códigos de análisis de laboratorio',
    color: 'from-emerald-500 to-emerald-700',
    categories: [...new Set(loinc?.data?.map(d => d.category) || [])]
  },
  { 
    id: 'rxnorm', 
    name: 'RxNorm', 
    fullName: 'Medication Codes',
    count: rxnorm?.data?.length || 0,
    description: 'Códigos de medicamentos (NLM)',
    color: 'from-purple-500 to-purple-700',
    categories: [...new Set(rxnorm?.data?.map(d => d.category) || [])]
  },
  { 
    id: 'snomed', 
    name: 'SNOMED CT', 
    fullName: 'Systematized Nomenclature of Medicine',
    count: snomed?.data?.length || 0,
    description: 'Conceptos clínicos internacionales',
    color: 'from-amber-500 to-amber-700',
    categories: [...new Set(snomed?.data?.map(d => d.category) || [])]
  }
];

const total = standards.reduce((sum, s) => sum + s.count, 0);
---

<BaseLayout title="Medical Standards Database - OrionHealth" description="Free medical codes database: ICD-10, LOINC, RxNorm, SNOMED CT. Searchable reference for healthcare.">
  
  <Header lang="en" />

  <main class="pt-20 pb-16 px-4">
    <div class="container-custom max-w-6xl mx-auto">
      
      <!-- Hero -->
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-6xl font-bold tracking-tighter uppercase mb-4">
          Medical <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-secondary">Standards</span>
        </h1>
        <p class="text-lg text-bone-dark opacity-80 max-w-2xl mx-auto">
          Base de conocimiento médico abierta con <strong class="text-white">{total.toLocaleString()}</strong> códigos en 4 estándares internacionales.
          Utilizada por OrionHealth para diagnóstico asistido por IA local.
        </p>
      </div>

      <!-- Stats overview -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
        {standards.map(s => (
          <div class="glass rounded-xl p-6 text-center hover:scale-105 transition-transform">
            <div class={`w-12 h-12 rounded-lg bg-gradient-to-br ${s.color} flex items-center justify-center mx-auto mb-3`}>
              <span class="text-white font-bold text-lg">{s.name.slice(0,2)}</span>
            </div>
            <div class="text-3xl font-bold text-white mb-1">{s.count.toLocaleString()}</div>
            <div class="text-xs text-bone-dark opacity-60">{s.name}</div>
          </div>
        ))}
      </div>

      <!-- Standard cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
        {standards.map(s => (
          <a href={`/OrionHealth/medical-standards/${s.id}`} class="group">
            <div class="glass rounded-xl p-6 hover:border-accent/50 transition-all duration-300 hover:scale-[1.02]">
              <div class="flex items-center justify-between mb-3">
                <div class={`w-10 h-10 rounded-lg bg-gradient-to-br ${s.color} flex items-center justify-center`}>
                  <span class="text-white font-bold text-sm">{s.name.slice(0,2)}</span>
                </div>
                <span class="text-2xl font-bold text-accent">{s.count}</span>
              </div>
              <h3 class="text-xl font-bold mb-1 group-hover:text-accent transition-colors">{s.fullName}</h3>
              <p class="text-sm text-bone-dark opacity-70 mb-2">{s.description}</p>
              <div class="flex flex-wrap gap-2">
                {s.categories.slice(0,4).map(cat => (
                  <span class="text-xs px-2 py-1 rounded-full bg-white/5 border border-white/10 text-bone-dark">
                    {cat}
                  </span>
                ))}
                {s.categories.length > 4 && (
                  <span class="text-xs px-2 py-1 rounded-full bg-white/5 text-bone-dark">
                    +{s.categories.length - 4} más
                  </span>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Data sources -->
      <div class="glass rounded-xl p-6">
        <h3 class="text-lg font-bold mb-3">Fuentes de Datos</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-sm">
          <div>
            <p class="text-bone-dark opacity-60">ICD-10: WHO / CMS</p>
            <p class="text-bone-dark opacity-60">LOINC: Regenstrief Institute</p>
          </div>
          <div>
            <p class="text-bone-dark opacity-60">RxNorm: NLM / UMLS</p>
            <p class="text-bone-dark opacity-60">SNOMED CT: SNOMED International</p>
          </div>
        </div>
        <p class="text-xs text-bone-dark opacity-40 mt-3">
          Esta base de datos es de uso libre. Los códigos son de dominio público / licencias abiertas.
          Powered by OrionHealth.
        </p>
      </div>

    </div>
  </main>

  <Footer lang="en" />
</BaseLayout>
