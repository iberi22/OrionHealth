---
import fs from "node:fs";
import Footer from "../../../components/Footer.astro";
import Header from "../../../components/Header.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
	const standards = ["icd-10", "loinc", "rxnorm", "snomed"];
	const files = {
		"icd-10": "icd10.json",
		loinc: "loinc.json",
		rxnorm: "rxnorm.json",
		snomed: "snomed.json",
	};
	const paths = [];
	for (const s of standards) {
		try {
			const content = fs.readFileSync(
				new URL(`../../../../public/${files[s]}`, import.meta.url),
				"utf-8",
			);
			const json = JSON.parse(content);
			for (const item of json.data || []) {
				paths.push({ params: { standard: s, code: item.code } });
			}
		} catch {}
	}
	return paths;
}

const standardId = Astro.params.standard;
const code = Astro.params.code;

const standardNames = {
	"icd-10": {
		name: "ICD-10",
		fullName: "International Classification of Diseases",
		file: "icd10.json",
		color: "from-blue-500 to-blue-700",
	},
	loinc: {
		name: "LOINC",
		fullName: "Logical Observation Identifiers",
		file: "loinc.json",
		color: "from-emerald-500 to-emerald-700",
	},
	rxnorm: {
		name: "RxNorm",
		fullName: "Medication Codes",
		file: "rxnorm.json",
		color: "from-purple-500 to-purple-700",
	},
	snomed: {
		name: "SNOMED CT",
		fullName: "Systematized Nomenclature of Medicine",
		file: "snomed.json",
		color: "from-amber-500 to-amber-700",
	},
};

const meta = standardNames[standardId];
if (!meta) {
	return Astro.redirect("/OrionHealth/medical-standards", 301);
}

let item = null;
let prevItem = null;
let nextItem = null;
try {
	const content = fs.readFileSync(`public/${meta.file}`, "utf-8");
	const json = JSON.parse(content);
	const data = json.data || [];
	const idx = data.findIndex((d) => d.code === code);
	if (idx >= 0) {
		item = data[idx];
		if (idx > 0) prevItem = data[idx - 1];
		if (idx < data.length - 1) nextItem = data[idx + 1];
	}
} catch {}

if (!item) {
	return Astro.redirect(`/OrionHealth/medical-standards/${standardId}`, 301);
}
---

<BaseLayout title={`${item.code} ${item.displayName} - ${meta.name} Code`} description={`${meta.name} code ${item.code}: ${item.displayName}. Category: ${item.category}.`}>
  
  <Header lang="en" />

  <main class="pt-20 pb-16 px-4">
    <div class="container-custom max-w-4xl mx-auto">
      
      <!-- Breadcrumb -->
      <div class="flex items-center gap-2 text-sm text-bone-dark opacity-60 mb-6">
        <a href="/OrionHealth/medical-standards" class="hover:text-accent transition-colors">Medical Standards</a>
        <span>/</span>
        <a href={`/OrionHealth/medical-standards/${standardId}`} class="hover:text-accent transition-colors">{meta.name}</a>
        <span>/</span>
        <span class="text-white">{item.code}</span>
      </div>

      <!-- Code header -->
      <div class="glass rounded-xl p-8 mb-6">
        <div class="flex items-center gap-4 mb-4">
          <div class={`w-16 h-16 rounded-xl bg-gradient-to-br ${meta.color} flex items-center justify-center`}>
            <span class="text-white font-bold text-2xl">{meta.name.slice(0,2)}</span>
          </div>
          <div>
            <h1 class="text-2xl md:text-4xl font-bold tracking-tight mb-1">
              <span class="font-mono text-accent">{item.code}</span>
            </h1>
            <p class="text-lg md:text-xl text-bone-dark opacity-80">{item.displayName}</p>
          </div>
        </div>

        <div class="flex flex-wrap gap-2 mb-4">
          <span class="text-xs px-3 py-1 rounded-full bg-white/5 border border-accent/20 text-accent">
            {item.category}
          </span>
          <span class="text-xs px-3 py-1 rounded-full bg-white/5 border border-white/10 text-bone-dark">
            {meta.fullName}
          </span>
        </div>

        <!-- Search terms -->
        {item.searchTerms && item.searchTerms.length > 0 && (
          <div>
            <h3 class="text-sm font-bold text-bone-dark opacity-60 mb-2">Términos de búsqueda</h3>
            <div class="flex flex-wrap gap-2">
              {item.searchTerms.map(term => (
                <a href={`/OrionHealth/medical-standards/${standardId}?q=${encodeURIComponent(term)}`}
                   class="text-xs px-3 py-1.5 rounded-lg bg-white/5 hover:bg-accent/10 border border-white/10 text-bone-dark hover:text-accent transition-all">
                  {term}
                </a>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Navigation -->
      <div class="flex justify-between gap-4">
        {prevItem ? (
          <a href={`/OrionHealth/medical-standards/${standardId}/${prevItem.code}`} 
             class="glass rounded-xl p-4 flex-1 hover:border-accent/30 transition-all group">
            <span class="text-xs text-bone-dark opacity-60 mb-1 block">← Anterior</span>
            <span class="font-mono text-sm text-accent">{prevItem.code}</span>
            <span class="text-xs text-bone-dark opacity-60 block truncate">{prevItem.displayName}</span>
          </a>
        ) : <div class="flex-1"></div>}
        
        {nextItem ? (
          <a href={`/OrionHealth/medical-standards/${standardId}/${nextItem.code}`}
             class="glass rounded-xl p-4 flex-1 text-right hover:border-accent/30 transition-all group">
            <span class="text-xs text-bone-dark opacity-60 mb-1 block">Siguiente →</span>
            <span class="font-mono text-sm text-accent">{nextItem.code}</span>
            <span class="text-xs text-bone-dark opacity-60 block truncate">{nextItem.displayName}</span>
          </a>
        ) : <div class="flex-1"></div>}
      </div>

    </div>
  </main>

  <Footer lang="en" />
</BaseLayout>
