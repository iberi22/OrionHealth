# Plausible Analytics Configuration
# Copy to .env to override defaults
# WARNING: Do not commit sensitive data to .env

# The domain registered in Plausible (defaults to orionhealth.app)
# PUBLIC_PLAUSIBLE_DOMAIN=orionhealth.app

# The URL of the Plausible script (defaults to https://plausible.io/js/script.js)
# PUBLIC_PLAUSIBLE_URL=https://plausible.io/js/script.js
