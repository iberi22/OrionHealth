scripts/_save_*.ps1

# Large model files (not committed)
assets/models/*.gguf
assets/models/*.bin
assets/models/*.safetensors
assets/models/*.pt

# Native binaries (platform-specific, not tracked)
*.dll
*.so
*.dylib

# Isar native binary (generated at build time)
isar.dll

# IDE
.idea/
.vscode/

# Medical data generation outputs
medical-standards/*.json
medical-standards/*.csv

# Node artifacts
node_modules/

# Git-Core artifacts
.gitcore/

# Python venv
.venv/
venv/
# Environment variables
.env

# Generated localization files (regenerated by flutter gen-l10n)
lib/l10n/app_localizations*.dart

# Golden test failure artifacts (local only)
test/widgets/failures/

# Debug/temp investigation scripts (not for public repo)
investigate_tests.js
